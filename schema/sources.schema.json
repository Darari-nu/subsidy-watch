{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://subsidy-watch.local/schema/sources.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "sources"],
  "properties": {
    "version": { "const": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "enabled", "name", "base_url", "public_base_url", "keywords"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "api" },
              "enabled": { "type": "boolean" },
              "name": { "type": "string", "minLength": 1 },
              "base_url": { "type": "string", "format": "uri" },
              "public_base_url": { "type": "string", "format": "uri" },
              "keywords": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "type", "enabled", "name", "url", "include_keywords"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "type": { "const": "rss" },
              "enabled": { "type": "boolean" },
              "name": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "format": "uri" },
              "include_keywords": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        ]
      }
    }
  }
}
