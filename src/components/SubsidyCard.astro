---
interface Subsidy {
  id: string;
  title: string;
  max_limit: number | null;
  area: string;
  employees: string;
  start: string | null;
  end: string;
  status: "new" | "closing_soon" | "open";
  source: "jgrants";
  jgrants_url: string;
  official_url: string | null;
  catch: string;
  first_seen: string;
}

interface Props {
  subsidy: Subsidy;
  today: string;
  index: number;
}

const { subsidy, today, index } = Astro.props;
const dayMs = 86_400_000;
const daysLeft = Math.max(
  0,
  Math.floor(
    (Date.parse(`${subsidy.end}T00:00:00Z`) -
      Date.parse(`${today}T00:00:00Z`)) /
      dayMs
  )
);
const daysSinceFirstSeen = Math.floor(
  (Date.parse(`${today}T00:00:00Z`) -
    Date.parse(`${subsidy.first_seen}T00:00:00Z`)) /
    dayMs
);
const isNew = daysSinceFirstSeen >= 0 && daysSinceFirstSeen <= 7;
const isClosing = subsidy.status === "closing_soon";
const formatDate = (date: string) =>
  new Intl.DateTimeFormat("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric"
  }).format(new Date(`${date}T00:00:00+09:00`));
const formatAmount = (amount: number | null) =>
  !amount
    ? "本文参照"
    : amount >= 100_000_000
      ? `${(amount / 100_000_000).toLocaleString("ja-JP", { maximumFractionDigits: 1 })}億円`
      : `${(amount / 10_000).toLocaleString("ja-JP", { maximumFractionDigits: 0 })}万円`;
---

<article
  class:list={[
    "subsidy-card relative overflow-hidden rounded-xl border bg-panel shadow-sm transition hover:-translate-y-0.5 hover:shadow-md",
    isClosing ? "border-danger/35" : "border-line",
    index % 3 === 0 ? "lg:col-span-2" : ""
  ]}
  data-area={subsidy.area}
  data-employees={subsidy.employees}
  data-amount={subsidy.max_limit ?? ""}
  data-title={subsidy.title.toLocaleLowerCase("ja")}
>
  <div class:list={["h-1.5", isClosing ? "bg-danger" : isNew ? "bg-gold" : "bg-green"]}></div>
  <div class="p-5 sm:p-6">
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span
        class:list={[
          "inline-flex items-center rounded-full px-3 py-1 text-xs font-black",
          isClosing ? "bg-danger-soft text-danger" : "bg-green/10 text-green"
        ]}
      >
        {daysLeft === 0 ? "本日締切" : `あと${daysLeft}日`}
      </span>
      {isClosing && (
        <span class="rounded-full border border-danger/25 px-2.5 py-1 text-[0.68rem] font-bold text-danger">
          締切間近
        </span>
      )}
      {isNew && (
        <span class="rounded-full bg-gold-soft px-2.5 py-1 text-[0.68rem] font-bold text-gold">
          NEW
        </span>
      )}
    </div>

    <p class="mb-2 text-xs font-bold text-muted">締切 {formatDate(subsidy.end)}</p>
    <h2 class="text-lg leading-relaxed font-bold sm:text-xl">{subsidy.title}</h2>
    {subsidy.catch && (
      <p class="mt-3 line-clamp-2 text-sm leading-7 text-muted">{subsidy.catch}</p>
    )}

    <dl class="mt-5 grid grid-cols-2 gap-x-4 gap-y-4 border-y border-line py-4 text-sm">
      <div>
        <dt class="mb-1 text-xs font-bold text-muted">補助上限</dt>
        <dd class="text-lg font-black text-green-dark">{formatAmount(subsidy.max_limit)}</dd>
      </div>
      <div>
        <dt class="mb-1 text-xs font-bold text-muted">対象地域</dt>
        <dd class="font-bold">{subsidy.area}</dd>
      </div>
      <div>
        <dt class="mb-1 text-xs font-bold text-muted">従業員規模</dt>
        <dd class="font-bold">{subsidy.employees}</dd>
      </div>
      <div>
        <dt class="mb-1 text-xs font-bold text-muted">受付開始</dt>
        <dd class="font-bold">{subsidy.start ? formatDate(subsidy.start) : "本文参照"}</dd>
      </div>
    </dl>

    <div class="mt-5 flex flex-wrap gap-2">
      <a
        class="link-button bg-green text-white hover:bg-green-dark"
        href={subsidy.jgrants_url}
        target="_blank"
        rel="noopener noreferrer"
      >
        jGrantsで確認
      </a>
      {subsidy.official_url && (
        <a
          class="link-button border border-line bg-white text-green hover:border-green"
          href={subsidy.official_url}
          target="_blank"
          rel="noopener noreferrer"
        >
          公式ページ
        </a>
      )}
    </div>
  </div>
</article>
